<?xml version="1.0" encoding="UTF-8"?>
<schemalist gettext-domain="gnome-shell-extensions">
    <schema id="org.gnome.shell.extensions.bluetooth_smartlock" path="/org/gnome/shell/extensions/bluetooth_smartlock/">
        <key name="active" type="b">
            <default>true</default>
            <summary>Activate</summary>
        </key>
        <key name="indicator" type="b">
            <default>false</default>
            <summary>Hide or show indicator</summary>
        </key>
        <key name="duration-in-seconds" type="i">
            <default>5</default>
            <range min="1" max="3600"/>
            <summary>Away duration (seconds)</summary>
        </key>
        <key name="mac" type="s">
            <default>''</default>
            <summary>Device mac address for tracking</summary>
        </key>
        <key name="auto-unlock" type="b">
            <default>false</default>
            <summary>Auto-unlock screen when device reconnects</summary>
        </key>
        <key name="proximity-lock" type="b">
            <default>false</default>
            <summary>Lock screen when RSSI drops below threshold</summary>
        </key>
        <key name="rssi-interval" type="i">
            <default>5</default>
            <range min="1" max="60"/>
            <summary>RSSI polling interval (seconds)</summary>
        </key>
        <key name="rssi-threshold" type="i">
            <default>-10</default>
            <range min="-100" max="0"/>
            <summary>RSSI threshold (dBm) below which the screen locks</summary>
        </key>
        <key name="last-seen" type="x">
            <default>0</default>
            <summary>Timestamp mac address was last seen</summary>
        </key>
    </schema>
</schemalist>
